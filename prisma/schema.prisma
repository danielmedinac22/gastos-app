generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum PaymentMethod {
  CASH
  CARD
}

model Category {
  id       String    @id @default(cuid())
  name     String    @unique
  icon     String    @default("📦")
  expenses      Expense[]
  fixedExpenses FixedExpense[]

  @@map("categories")
}

model CreditCard {
  id          String   @id @default(cuid())
  name        String
  creditLimit Decimal? @db.Decimal(12, 2)
  cutOffDay   Int
  paymentDay  Int
  color       String   @default("#3B82F6")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  billingCycles BillingCycle[]
  expenses      Expense[]
  fixedExpenses FixedExpense[]

  @@map("credit_cards")
}

model BillingCycle {
  id           String     @id @default(cuid())
  creditCardId String
  creditCard   CreditCard @relation(fields: [creditCardId], references: [id], onDelete: Cascade)
  startDate    DateTime   @db.Date
  endDate      DateTime   @db.Date
  paymentDate  DateTime   @db.Date
  totalAmount  Decimal    @default(0) @db.Decimal(12, 2)
  isPaid       Boolean    @default(false)
  isClosed     Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  expenses Expense[]

  @@unique([creditCardId, startDate])
  @@index([creditCardId, endDate])
  @@map("billing_cycles")
}

model Expense {
  id            String        @id @default(cuid())
  amount        Decimal       @db.Decimal(12, 2)
  description   String?
  date          DateTime      @db.Date
  paymentMethod PaymentMethod

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  creditCardId   String?
  creditCard     CreditCard?   @relation(fields: [creditCardId], references: [id])
  billingCycleId String?
  billingCycle   BillingCycle? @relation(fields: [billingCycleId], references: [id])

  fixedExpenseId String?
  fixedExpense   FixedExpense? @relation(fields: [fixedExpenseId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@index([billingCycleId])
  @@map("expenses")
}

model FixedExpense {
  id            String        @id @default(cuid())
  name          String
  amount        Decimal       @db.Decimal(12, 2)
  dayOfMonth    Int
  paymentMethod PaymentMethod
  isActive      Boolean       @default(true)

  creditCardId String?
  creditCard   CreditCard? @relation(fields: [creditCardId], references: [id])
  categoryId   String
  category     Category    @relation(fields: [categoryId], references: [id])

  expenses Expense[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("fixed_expenses")
}

model Settings {
  id            String  @id @default("default")
  monthlyIncome Decimal @default(0) @db.Decimal(12, 2)

  @@map("settings")
}

model Income {
  id         String   @id @default(cuid())
  name       String
  amount     Decimal  @db.Decimal(12, 2)
  dayOfMonth Int
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("incomes")
}
